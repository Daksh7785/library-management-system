# ============================================================
# AcademicOS — Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================================

# --- Supabase (PostgreSQL + Auth) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Meilisearch (Search Engine) ---
VITE_MEILISEARCH_HOST=http://localhost:7700
VITE_MEILISEARCH_API_KEY=your_meili_api_key

# --- Cloudflare R2 (Cover Image Storage) ---
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=academicos-covers
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_PUBLIC_URL=https://covers.yourdomain.com

# --- Google Books API ---
GOOGLE_BOOKS_API_KEY=your_google_books_key

# --- AI (pick one) ---
OPENAI_API_KEY=your_openai_key
# GEMINI_API_KEY=your_gemini_key

# --- Redis (BullMQ Workers) ---
REDIS_URL=redis://localhost:6379

# --- SMTP (Supabase uses its own, but for custom: Resend/SendGrid) ---
# SMTP_API_KEY=your_smtp_key
